{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri-conf-v2.schema.json",
  "productName": "Claude Command Center",
  "version": "0.1.0",
  "identifier": "com.scouto.claude-command-center",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Command Center",
        "width": 300,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "dragDropEnabled": true,
        "acceptFirstMouse": true,
        "x": 1500,
        "y": 0
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
